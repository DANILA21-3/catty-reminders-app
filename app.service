[Unit]
Description=Catty App
After=network.target

[Service]
Type=simple
User=da
WorkingDirectory=/home/da/Рабочий стол/lab2
EnvironmentFile=/home/da/Рабочий стол/lab2/.env
ExecStart=/usr/bin/python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8181
Restart=always

[Install]
WantedBy=multi-user.target
